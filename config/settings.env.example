# =============================================
# Git Sync System — Settings Template
# Copy to settings.env and fill in your values
# NEVER commit settings.env with real tokens!
# Use token-manager.py to store tokens securely
# =============================================

# ── GitHub ──
GITHUB_USERNAME=your_username
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Git Config ──
# token | ssh | store
AUTH_METHOD=token
GIT_NAME=Your Name
GIT_EMAIL=your@email.com

# ── HuggingFace ──
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Telegram ──
TELEGRAM_API_ID=your_api_id
TELEGRAM_API_HASH=your_api_hash

# ── AI APIs (optional) ──
DEEPSEEK_API_KEY=
GROQ_API_KEY=
OPENROUTER_API_KEY=
OPENAI_API_KEY=
ZAI_API_KEY=
CURSOR_API_KEY=

# ── Sync Settings ──
PULL_REBASE=true
PUSH_FORCE=false
WATCH_INTERVAL=300
AUTO_COMMIT_MSG="sync: auto-sync %r [%d %t]"
WATCH_EXTENSIONS=.py,.json,.yaml,.yml,.md,.txt,.cfg,.toml,.ini,.sh,.js,.ts,.html,.css
IGNORE_PATTERNS=.git,__pycache__,*.pyc,.idea,node_modules,.venv,venv,.DS_Store,*.egg-info